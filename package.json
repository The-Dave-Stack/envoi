{
  "name": "envoi",
  "version": "0.1.0",
  "description": "Environment-agnostic configuration orchestrator with OpenBao and HashiCorp Vault support",
  "main": "dist/index.js",
  "bin": {
    "envoi": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "clean": "rimraf dist",
    "clean:all": "rimraf dist node_modules package-lock.json",
    "prepublishOnly": "npm run clean && npm run build",
    "envoi:test": "echo \"This is a test\""
  },
  "keywords": [
    "environment",
    "configuration",
    "env",
    "secrets",
    "openbao",
    "vault",
    "cli",
    "deployment",
    "devops"
  ],
  "author": "David (The Dave Stack)",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
    "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^14.0.1",
    "dotenv": "^17.2.2",
    "node-fetch": "^3.3.2",
    "yaml": "^2.8.1",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.5.0",
    "@typescript-eslint/eslint-plugin": "^8.44.0",
    "@typescript-eslint/parser": "^8.44.0",
    "eslint": "^9.35.0",
    "jest": "^30.1.3",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
