{
  "name": "envoi",
  "version": "1.0.0",
  "description": "Environment-agnostic configuration orchestrator with OpenBao and HashiCorp Vault support",
  "main": "dist/index.js",
  "bin": {
    "envoi": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "envoi:test": "echo \"This is a test\""
  },
  "keywords": [
    "environment",
    "configuration",
    "env",
    "secrets",
    "openbao",
    "vault",
    "cli",
    "deployment",
    "devops"
  ],
  "author": "David (The Dave Stack)",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "dotenv": "^16.4.5",
    "node-fetch": "^3.3.2",
    "yaml": "^2.4.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.9",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
